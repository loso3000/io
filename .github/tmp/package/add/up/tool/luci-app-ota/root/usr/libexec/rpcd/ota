. /usr/share/libubox/jshn.sh

log() {
    logger -t ota-rpcd "[$$] $*"
}

image_supported() {
    local image="$1"
    /sbin/sysupgrade -T "$image" >/dev/null 2>&1
    return $?
}

get_current_ip() {
    local ip=""
    ip=$(uci -q get network.lan.ipaddr)
    [ -z "$ip" ] && ip="${HTTP_HOST:-192.168.10.1}"
    ip=$(echo "$ip" | cut -d: -f1 | cut -d/ -f1)
    [ -z "$ip" ] && ip="192.168.10.1"
    echo "$ip"
}

get_firmware_ip() {
    local json_file="/tmp/run/ezota/ezota.json"
    local default_ip="192.168.10.1"

    if [ -f "$json_file" ]; then
        local ip=$(cat "$json_file" | grep -o '"ip"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | cut -d'"' -f4)
        [ -n "$ip" ] && echo "$ip" || echo "$default_ip"
    else
        echo "$default_ip"
    fi
}

get_target_ip() {
    local keep="$1"
    local expsize="$2"

    local current_ip=$(get_current_ip)
    local firmware_ip=$(get_firmware_ip)

    if [ "$keep" = "1" -a "$expsize" = "0" ]; then
        echo "$current_ip"
    else
        echo "$firmware_ip"
    fi
}

image_comped() {
    local image_file="$1"

    if [ ! -f "$image_file" ]; then
        return 1
    fi

    if file "$image_file" | grep -q "gzip compressed data"; then
        return 0
    elif file "$image_file" | grep -q "filesystem data"; then
        return 0
    else
        return 1
    fi
}

get_system_disk() {
    rom_dev=$(df -h | grep boot | awk '{print $1}' | head -1 )
    [ -z "${rom_dev}" ] && rom_dev=$(mount | grep ' /boot' | awk '{print $1}' 2>/dev/null)
    [ -z "${rom_dev}" ] && rom_dev=$(df -P /boot 2>/dev/null | awk 'NR==2 {print $1}')
    [ -z "${rom_dev}" ] && rom_dev=$(blkid -t TYPE="squashfs" | awk -F : '{print $1}')
    [ -z "${rom_dev}" ] && TDISK=$(lsblk -l -o NAME,MOUNTPOINTS | grep -E '/rom' | grep -v '/rom/' | head -1 | awk '{print $1}') && rom_dev="/dev/$TDISK"

    local disk=""
    if [ -n "$rom_dev" ]; then
        case "$rom_dev" in
            /dev/sd[a-z][0-9]*)
                disk=$(echo "$rom_dev" | sed 's/[0-9]*$//')
                ;;
            /dev/nvme[0-9]*n[0-9]*p[0-9]*)
                disk=$(echo "$rom_dev" | sed 's/p[0-9]*$//')
                ;;
            /dev/mmcblk[0-9]*p[0-9]*)
                disk=$(echo "$rom_dev" | sed 's/p[0-9]*$//')
                ;;
            /dev/vd[a-z][0-9]*)
                disk=$(echo "$rom_dev" | sed 's/[0-9]*$//')
                ;;
            /dev/mtdblock*)
                disk="$rom_dev"
                ;;
            /dev/ubiblock*)
                disk="$rom_dev"
                ;;
            /dev/root)
                # 特殊处理 /dev/root
                disk=$(lsblk -no PKNAME / 2>/dev/null)
                if [ -n "$disk" ]; then
                    disk="/dev/$disk"
                fi
                ;;
            *)
                # 尝试通用匹配
                if echo "$rom_dev" | grep -qE '^/dev/[a-z]+[0-9]+'; then
                    disk=$(echo "$rom_dev" | sed 's/[0-9]*$//')
                fi
                ;;
        esac
    fi

    if [ -n "$disk" ] && [ ! -b "$disk" ]; then
        disk=""
    fi

    echo "$disk"
}

get_disk_size_kb() {
    local disk="$1"
    local device=$(basename "$disk" 2>/dev/null)
    local size_kb=0

    if [ ! -b "$disk" ]; then
        echo 0
        return
    fi

    if command -v lsblk >/dev/null 2>&1; then
        local size_bytes=$(lsblk -b -n -o SIZE "$disk" 2>/dev/null | head -1)
        [ -n "$size_bytes" ] && size_kb=$((size_bytes / 1024 ))
    elif [ -f "/sys/block/$device/size" ]; then
        local num_sectors=$(cat "/sys/block/$device/size" 2>/dev/null)
        if [ -n "$num_sectors" ]; then
            local sector_size=512
            if [ -f "/sys/block/$device/queue/logical_block_size" ]; then
                sector_size=$(cat "/sys/block/$device/queue/logical_block_size" 2>/dev/null)
                [ -z "$sector_size" ] && sector_size=512
            fi
            size_kb=$((num_sectors * sector_size / 1024 ))
        fi
    elif command -v fdisk >/dev/null 2>&1; then
        local output=$(fdisk -l "$disk" 2>/dev/null)
        local size_bytes=$(echo "$output" | grep -E "^Disk.*bytes" | grep -oE '[0-9]+ bytes' | head -1 | cut -d' ' -f1)
        [ -n "$size_bytes" ] && size_kb=$((size_bytes / 1024 ))
    fi
    echo $size_kb
}
get_disk_free_mb() {
    local disk="$1"
    if [ -b "$disk" ]; then
        local free_space=$(lsblk -b "$disk" -o SIZE | tail -1)
        echo $((free_space / 1024 / 1024))
    else
        echo 0
    fi
}

get_disk_freedisk_kb() {
    local path="$1"
    if [ -d "$path" ] || [ -f "$path" ]; then
        df -k "$path" 2>/dev/null | tail -1 | awk '{print $4}'
    else
        echo 0
    fi
}

get_decompressed_size() {
    local image_file="$1"
    local decompressed_size=0
    if image_comped "$image_file"; then
        decompressed_size=$(gzip -dc "$image_file" 2>/dev/null | wc -c)
    else
        decompressed_size=$(du -sb "$image_file" 2>/dev/null | cut -f1)
    fi
    echo ${decompressed_size:-0}
}


manual_get_firmware_info() {
    local filepath="$1"
    
    if [ ! -f "$filepath" ]; then
        json_init
        json_add_int code 1
        json_add_string msg "File not found"
        json_dump
        return
    fi
    
    local filename=$(basename "$filepath")
    local filesize=$(stat -c%s "$filepath" 2>/dev/null || echo "0")
    local md5=$(md5sum "$filepath" | cut -d' ' -f1)
    local version="Unknown"
    local ip="192.168.10.1"
    
    if echo "$filename" | grep -qE '[0-9]+\.[0-9]+\.[0-9]+'; then
        version=$(echo "$filename" | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1)
    fi
    
    json_init
    json_add_int code 0
    json_add_string filename "$filename"
    json_add_int size $filesize
    json_add_string md5 "$md5"
    json_add_string version "$version"
    json_add_string ip "$ip"
    json_dump
}

manual_list_firmware() {
    local first=true
    
    json_init
    json_add_int code 0
    json_add_array files
    
    for file in /tmp/*.bin /tmp/*.img /tmp/*.trx /tmp/*.gz; do
        [ -f "$file" ] || continue
        
        local name=$(basename "$file")
        local size=$(stat -c%s "$file" 2>/dev/null || echo "0")
        
        json_add_object
        json_add_string name "$name"
        json_add_string path "$file"
        json_add_int size $size
        json_close_object
    done
    
    json_close_array
    json_dump
}

manual_delete_firmware() {
    local filepath="$1"
    
    # 安全检查：只允许删除/tmp下的文件
    if ! echo "$filepath" | grep -q "^/tmp/"; then
        json_init
        json_add_int code 1
        json_add_string msg "Invalid file path"
        json_dump
        return
    fi
    
    if [ -f "$filepath" ]; then
        rm -f "$filepath"
        json_init
        json_add_int code 0
        json_add_string msg "File deleted"
        json_dump
    else
        json_init
        json_add_int code 1
        json_add_string msg "File not found"
        json_dump
    fi
}

manual_do_flash() {
    local keep="$1"
    local expsize="$2"
    local bopkg="$3"
    local filepath="$4"
    
    if [ ! -f "$filepath" ]; then
        json_init
        json_add_int code 1
        json_add_string msg "Firmware file not found"
        json_dump
        return
    fi
    
    local target_ip=$(get_target_ip "$keep" "$expsize")
    
    local LOG_FILE="/tmp/ezotaflash.log"
    echo "Starting manual flash at $(date)" > $LOG_FILE
    echo "Firmware: $(basename $filepath)" >> $LOG_FILE
    echo "Mode: $([ "$expsize" = "0" ] && echo "Sysupgrade" || echo "DD Mode")" >> $LOG_FILE
    echo "Keep settings: $keep" >> $LOG_FILE
    echo "Target IP: $target_ip" >> $LOG_FILE
    
    (
        sleep 1
        execute_flash_script "$keep" "$expsize" "$bopkg" "$filepath"
    ) >/dev/null 2>&1 &
    
    json_init
    json_add_int code 0
    json_add_string msg "Flash process started"
    json_add_string target_ip "$target_ip"
    json_dump
}

get_system_free_space() {
    local path="$1"
    local free_kb=0
    
    if [ -d "$path" ]; then
        free_kb=$(df -k "$path" 2>/dev/null | tail -1 | awk '{print $4}')
    fi
    
    echo $((free_kb / 1024))
}

get_best_storage_path() {
    local required_size="$1"  # 需要的空间大小（MB）
    local best_path=""
    local max_space=0
    
    local overlay_free=$(get_system_free_space "/overlay")
    if [ $overlay_free -gt $required_size ]; then
        echo "/overlay"
        return
    fi
    
    local tmp_free=$(get_system_free_space "/tmp")
    if [ $tmp_free -gt $required_size ]; then
        echo "/tmp"
        return
    fi
    
    if [ -f "/etc/partexppath" ]; then
        local partexp_path=$(head -n 1 /etc/partexppath 2>/dev/null | awk '{print $1}' | tr -d '\n')
        if [ -n "$partexp_path" ] && [ -d "$partexp_path" ]; then
            local partexp_free=$(get_system_free_space "$partexp_path")
            if [ $partexp_free -gt $required_size ]; then
                echo "$partexp_path"
                return
            elif [ $partexp_free -gt $max_space ]; then
                max_space=$partexp_free
                best_path="$partexp_path"
            fi
        fi
    fi
    
    if [ -n "$best_path" ]; then
        echo "$best_path"
        return
    fi
    echo "/tmp"
}

get_max_space_path() {
    local max_space=0
    local best_path="/tmp"
    
    local overlay_free=$(get_system_free_space "/overlay")
    if [ $overlay_free -gt $max_space ]; then
        max_space=$overlay_free
        best_path="/overlay"
    fi
    
    local tmp_free=$(get_system_free_space "/tmp")
    if [ $tmp_free -gt $max_space ]; then
        max_space=$tmp_free
        best_path="/tmp"
    fi
    
    if [ -f "/etc/partexppath" ]; then
        local partexp_path=$(head -n 1 /etc/partexppath 2>/dev/null | awk '{print $1}' | tr -d '\n')
        if [ -n "$partexp_path" ] && [ -d "$partexp_path" ]; then
            local partexp_free=$(get_system_free_space "$partexp_path")
            if [ $partexp_free -gt $max_space ]; then
                max_space=$partexp_free
                best_path="$partexp_path"
            fi
        fi
    fi
    
    echo "$best_path"
}

execute_flash_script() {
    local keep="$1"
    local expsize="$2"
    local bopkg="$3"
    local IMAGE_TMP="${4:-/tmp/firmware.img}"
    local LOG_FILE="/tmp/ezotaflash.log"
    
    echo "Starting flash at $(date)" >> $LOG_FILE
    chmod 644 $LOG_FILE
    sleep 1

    echo "Verify firmware files" >> $LOG_FILE

    if [ "$expsize" = "0" ] && ! image_supported "$IMAGE_TMP"; then
        echo "ERROR: Invalid firmware image" >> $LOG_FILE
        exit 1
    fi
    
    upsys_disk=$(get_system_disk)
    upsys_disk_size=$(get_disk_size_kb "$upsys_disk")
    upsys_disk_size_mb=$((upsys_disk_size / 1024))

    ORIGINAL_SIZE=$(get_decompressed_size "$IMAGE_TMP")
    ORIGINAL_SIZE_MB=$((ORIGINAL_SIZE / 1024 / 1024))

    echo "Upgrade system space: $((upsys_disk_size_mb / 1024))GB ($upsys_disk_size_mb MB)" >> $LOG_FILE
    echo "Image size: $((ORIGINAL_SIZE_MB / 1024))GB ($ORIGINAL_SIZE_MB MB)" >> $LOG_FILE

    target_ip=$(get_target_ip "$keep" "$expsize")
    echo "WEB IP Address: $target_ip" >> $LOG_FILE
    sleep 1

    local required_space_mb=$((ORIGINAL_SIZE_MB * 110 / 100))
    
    cat > /tmp/otaflash.sh << 'EOF'
#!/bin/sh
LOG_FILE="/tmp/ezotaflash.log"
IMAGE_TMP="$1"
EOF

    if [ "$expsize" -gt 0 ]; then
        echo "DD flash mode" >> $LOG_FILE
        
        local save_image_disk=$(get_best_storage_path $required_space_mb)
        
        if [ ! -w "$save_image_disk" ]; then
            echo "Error: Storage path $save_image_disk is not writable!" >> $LOG_FILE
            save_image_disk=$(get_max_space_path)
            if [ ! -w "$save_image_disk" ]; then
                echo "Error: No writable storage path found!" >> $LOG_FILE
                exit 1
            fi
        fi
        
        local save_image_disk_file="${save_image_disk}/image_extracted.img"
        local save_image_disk_free_mb=$(get_system_free_space "$save_image_disk")
        
        echo "Using storage path: $save_image_disk (free: ${save_image_disk_free_mb}MB)" >> $LOG_FILE
        
        rm -f "$save_image_disk_file" 2>/dev/null || true
        
        local upsys_exp_size=$((upsys_disk_size_mb - 1024))  # 保留1%空间
        if [ $save_image_disk_free_mb -lt $required_space_mb ]; then
            echo "Error: Insufficient disk space at $save_image_disk" >> $LOG_FILE
            echo "Need: ${required_space_mb} MB, Available: ${save_image_disk_free_mb} MB" >> $LOG_FILE
            exit 1
        fi

        echo "Extracting firmware..." >> $LOG_FILE
        
        if file "$IMAGE_TMP" | grep -q "gzip compressed data"; then
            if gzip -dc "$IMAGE_TMP" > "$save_image_disk_file" 2>>$LOG_FILE; then
                actual_size=$(du -sb "$save_image_disk_file" 2>/dev/null | cut -f1)
                if [ "$actual_size" -eq "$ORIGINAL_SIZE" ]; then
                    echo "Decompression successful: $((actual_size / 1024 / 1024)) MB" >> $LOG_FILE
                else
                    echo "Warning: File size mismatch. Expected: $ORIGINAL_SIZE, Actual: $actual_size" >> $LOG_FILE
                fi
            else
                echo "ERROR: Failed to extract firmware" >> $LOG_FILE
                exit 1
            fi
        else
            cp "$IMAGE_TMP" "$save_image_disk_file" 2>>$LOG_FILE
            echo "Copied firmware file: $(du -sh "$save_image_disk_file" | cut -f1)" >> $LOG_FILE
        fi
        
        echo "Additional expansion capacity" >> $LOG_FILE
        
        case $expsize in
            1) dd_size=0 ;; 
            2) dd_size=4096 ;;
            3) dd_size=10240 ;;
            4) dd_size=20480 ;;
            5) dd_size=51200 ;;
            6) dd_size=102400 ;;
            *) dd_size=0 ;;
        esac

        if [ $dd_size -gt 0 ]; then
            local available_for_expansion=$((save_image_disk_free_mb - ORIGINAL_SIZE_MB))
            
            if [ $dd_size -gt $available_for_expansion ]; then
                EXPANSION_MB=$available_for_expansion
                echo "Warning: Expansion size limited by available space. Using: ${EXPANSION_MB}MB" >> $LOG_FILE
            else
                EXPANSION_MB=$dd_size
            fi
        elif [ $upsys_exp_size -gt 0 ]; then
            local available_for_expansion=$((save_image_disk_free_mb - ORIGINAL_SIZE_MB))
            if [ $upsys_exp_size -gt $available_for_expansion ]; then
                EXPANSION_MB=$available_for_expansion
                echo "AUTO: Using maximum available space: ${EXPANSION_MB}MB" >> $LOG_FILE
            else
                EXPANSION_MB=$upsys_exp_size
                echo "AUTO: Using system expansion size: ${EXPANSION_MB}MB" >> $LOG_FILE
            fi
        else
            EXPANSION_MB=0
        fi
        
        if [ $EXPANSION_MB -gt 0 ]; then
            echo "Expanding image by ${EXPANSION_MB}MB" >> $LOG_FILE
            if dd if=/dev/zero bs=1M count=$EXPANSION_MB >> "$save_image_disk_file" 2>>$LOG_FILE; then
                echo "Expansion successful" >> $LOG_FILE
            else
                echo "Warning: Expansion failed, continuing with original size" >> $LOG_FILE
            fi
        else
            echo "No expansion requested" >> $LOG_FILE
        fi

        cat >> /tmp/otaflash.sh << EOF

echo "Fix GPT expansion partition" >> \$LOG_FILE
if command -v sgdisk >/dev/null 2>&1; then
    sgdisk -e "$save_image_disk_file" >/dev/null 2>&1 || true
else
    echo "sgdisk not found, skipping GPT fix" >> \$LOG_FILE
fi

echo "Expand partition" >> \$LOG_FILE
if command -v parted >/dev/null 2>&1; then
    echo -e "resizepart 2 -1\\nq" | parted "$save_image_disk_file"  2>>\$LOG_FILE
else
    echo "parted not found, skipping partition resize" >> \$LOG_FILE
fi

echo "Writing image to flash" >> \$LOG_FILE
sleep 2
echo "Stopping services..." >> \$LOG_FILE
killall dropbear uhttpd nginx 2>/dev/null || true
sleep 2
sync
echo "Rebooting system" >> \$LOG_FILE
sleep 5
echo "DD writing image to $upsys_disk..." >> \$LOG_FILE
if dd if="$save_image_disk_file" of="$upsys_disk" bs=4k conv=fsync  2>>\$LOG_FILE; then
    echo "DD write completed successfully" >> \$LOG_FILE
else
    echo "ERROR: DD write failed" >> \$LOG_FILE
    exit 1
fi

echo "Flash completed at \$(date)" >> \$LOG_FILE
sync
sleep 3
echo b > /proc/sysrq-trigger
EOF
    else
        echo "Sysupgrade flash mode" >> $LOG_FILE
        local args=""
        [ "$keep" != "1" ] && args="$args -n"
        [ "$bopkg" != "1" ] && args="$args -k"

        cat >> /tmp/otaflash.sh << EOF

echo "Running sysupgrade command" >> \$LOG_FILE
sleep 3
echo "Stopping services..." >> \$LOG_FILE
killall dropbear uhttpd nginx 2>/dev/null || true
sleep 2
echo "Upgrade completed" >> \$LOG_FILE
sleep 5

echo "Rebooting system" >> \$LOG_FILE
sync

echo "Executing sysupgrade" >> \$LOG_FILE
/sbin/sysupgrade -v $args "\$IMAGE_TMP" 2>>\$LOG_FILE
echo "Sysupgrade command executed" >> \$LOG_FILE
sleep 5
echo b > /proc/sysrq-trigger
EOF
    fi

    cat >> /tmp/otaflash.sh << 'EOF'
echo "Flash script completed at \$(date)" >> $LOG_FILE

EOF
    chmod +x /tmp/otaflash.sh
    echo "Executing flash script" >> $LOG_FILE
    /bin/sh /tmp/otaflash.sh "$IMAGE_TMP" >/dev/null 2>&1 &

    echo $! > /tmp/otaflash.pid
    echo "Flash script started with PID: $!" >> $LOG_FILE
    return 0
}



case "$1" in
    list)
        cat << 'EOF'
{
    "check": {
        "method": "check"
    },
    "info": {
        "method": "info"
    },
    "download": {
        "method": "download"
    },
    "progress": {
        "method": "progress"
    },
    "cancel": {
        "method": "cancel"
    },
    "do_flash": {
        "method": "do_flash",
        "params": ["keep", "expsize", "bopkg"]
    },
    "flash_progress": {
        "method": "flash_progress"
    },
    "get_target_ip": {
        "method": "get_target_ip",
        "params": ["keep", "expsize"]
    },
    "manual_get_firmware_info": {
        "method": "manual_get_firmware_info",
        "params": ["filepath"]
    },
    "manual_list_firmware": {
        "method": "manual_list_firmware"
    },
    "manual_delete_firmware": {
        "method": "manual_delete_firmware",
        "params": ["filepath"]
    },
    "manual_do_flash": {
        "method": "manual_do_flash",
        "params": ["keep", "expsize", "bopkg", "filepath"]
    }
}
EOF
        ;;
        
    call)
        method="$2"
        
        if [ -z "$method" ]; then
            json_init
            json_add_int code 400
            json_add_string msg "Method name is empty"
            json_dump
            exit 0
        fi
        
        case "$method" in
            check|download|cancel|progress)
                output=$(/bin/ota "$method" 2>&1)
                ret=$?
                json_init
                json_add_int code $ret
                json_add_string msg "$output"
                json_dump
                ;;
                
            info)
                if [ -f "/tmp/run/ezota/ezota.json" ]; then
                    output=$(cat /tmp/run/ezota/ezota.json)
                    ret=0
                else
                    output="{}"
                    ret=1
                fi
                json_init
                json_add_int code $ret
                json_add_string msg "$output"
                json_dump
                ;;
                
            flash_progress)
                json_init
                
                if [ -f "/tmp/ezotaflash.log" ]; then
                    # 读取日志
                    log_content=$(tail -50 /tmp/ezotaflash.log 2>/dev/null)
                    json_add_string log "$log_content"
                    
                    # 解析进度状态
                    progress=0
                    status="running"
                    message="Starting flash process"
                    
                    # 检查各个阶段
                    if echo "$log_content" | grep -q "Flash script completed"; then
                        progress=100
                        status="complete"
                        message="Flash complete!"
                    elif echo "$log_content" | grep -q "Sysupgrade command executed"; then
                        progress=100
                        status="complete"
                        message="Flash complete!"
                    elif echo "$log_content" | grep -q "DD write completed"; then
                        progress=100
                        status="complete"
                        message="Flash complete!"
                    elif echo "$log_content" | grep -q "Rebooting system"; then
                        progress=100
                        status="rebooting"
                        message="Flash complete! Rebooting"
                    elif echo "$log_content" | grep -q "Upgrade completed"; then
                        progress=90
                        status="finalizing"
                        message="Finalizing flash process"
                    elif echo "$log_content" | grep -q "Writing image to flash"; then
                        progress=70
                        status="flashing"
                        message="Writing firmware to flash"
                    elif echo "$log_content" | grep -q "Running sysupgrade command"; then
                        progress=70
                        status="upgrading"
                        message="Running sysupgrade command"
                    elif echo "$log_content" | grep -q "Fix GPT expansion partition"; then
                        progress=60
                        status="expanding"
                        message="Fixing GPT partition table"
                    elif echo "$log_content" | grep -q "Additional expansion capacity"; then
                        progress=50
                        status="expanding"
                        message="Adding expansion capacity"
                    elif echo "$log_content" | grep -q "Preparing extracted image"; then
                        progress=25
                        status="preparing"
                        message="Preparing extracted image"
                    elif echo "$log_content" | grep -q "Verify firmware files"; then
                        progress=10
                        status="verifying"
                        message="Verifying firmware files"
                    elif echo "$log_content" | grep -q "flash mode"; then
                        progress=5
                        status="flashing"
                        message="Flash mode"
                    # 检查失败状态
                    elif echo "$log_content" | grep -qi "error\|fail"; then
                        progress=0
                        status="failed"
                        # 提取错误信息
                        error_msg=$(echo "$log_content" | grep -i "error\|fail" | tail -1)
                        if [ -n "$error_msg" ]; then
                            message="Flash failed: $error_msg"
                        else
                            message="Flash failed! Check log for details"
                        fi
                    fi
                    
                    json_add_string status "$status"
                    json_add_int progress "$progress"
                    json_add_string message "$message"
                else
                    json_add_string status "idle"
                    json_add_int progress 0
                    json_add_string message "No flash in progress"
                    json_add_string log ""
                fi
                
                json_dump
                ;;
                
            get_target_ip)
                # 读取输入
                json_input=$(cat)
                keep="1"
                expsize="0"
                
                if [ -n "$json_input" ]; then
                    json_load "$json_input"
